---
/**
 * index.astro
 * Main exam-tracker page.
 *
 * Layout structure (matches Stitch reference Exam-Tracker-Deadline-Machine.html):
 *   1. Fixed top app-bar   — DEADLINE_PROTOCOL title + nav links
 *   2. Date anchor section — system status + today's date (dd-mm-yyyy, client-rendered)
 *   3. Exam card list      — <Schedule /> component
 *   4. Footer              — NO_EXCUSES motto
 *   5. Fixed bottom nav    — mobile navigation bar
 *
 * Visual source of truth: stitch/2944944676816621264/668a3253350e441690c92f6971809c95/Exam-Tracker-Deadline-Machine.html
 */
import '../styles/global.css';
import '../styles/home.css';
import Schedule from '../components/Schedule.astro';
---

<!doctype html>
<html class="dark" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Exam countdown tracker — DEADLINE_PROTOCOL" />
    <title>DEADLINE_PROTOCOL</title>

    <!-- Fonts: Space Grotesk (display/body) + JetBrains Mono (countdowns) -->
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;700;800;900&family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <!-- Material Symbols for icons -->
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-background text-on-surface antialiased mb-24">

    <!-- ── Top App Bar ──────────────────────────────────────────── -->
    <header
      class="fixed top-0 w-full z-50 flex items-center justify-between px-6 py-4
             bg-background border-b-4 border-white hard-shadow-white"
    >
      <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-primary text-2xl">terminal</span>
        <h1 class="text-2xl font-black text-white tracking-widest font-headline uppercase">
          DEADLINE_PROTOCOL
        </h1>
      </div>

      <div class="flex items-center gap-4">
        <nav class="hidden md:flex gap-6 font-headline font-bold text-sm tracking-widest uppercase">
          <a class="text-primary" href="#">Grid</a>
          <a class="text-white hover:text-primary" href="#">Add</a>
          <a class="text-white hover:text-primary" href="#">Stats</a>
          <a class="text-white hover:text-primary" href="#">Meta</a>
        </nav>
        <span class="material-symbols-outlined text-white cursor-pointer hover:bg-primary hover:text-black p-1">
          history_toggle_off
        </span>
      </div>
    </header>

    <!-- ── Main content ─────────────────────────────────────────── -->
    <main class="mt-28 px-4 max-w-2xl mx-auto space-y-12">

      <!-- Date Anchor -->
      <section class="flex justify-between items-end border-b-4 border-outline pb-2">
        <div>
          <span class="block text-[10px] font-black uppercase tracking-[0.2em] text-outline">
            System_Status
          </span>
          <span class="text-4xl font-black font-headline tracking-tighter">OPERATIONAL</span>
        </div>
        <div class="text-right">
          <span class="block text-[10px] font-black uppercase tracking-[0.2em] text-outline">
            Current_Date
          </span>
          <span
            id="today-date"
            class="text-xl font-mono font-bold text-primary"
            aria-live="polite"
          >
            ──-──-────
          </span>
        </div>
      </section>

      <!-- Exam schedule -->
      <Schedule />

      <!-- Footer -->
      <section class="border-t-8 border-white pt-6 pb-12">
        <h3 class="text-6xl font-black font-headline italic tracking-tighter uppercase leading-none">
          NO_EXCUSES
        </h3>
        <p class="font-mono text-outline mt-4 text-xs max-w-xs uppercase leading-relaxed">
          Time is a finite physical resource. Every second spent in hesitation
          is a secondary loss of intellectual potential.
        </p>
      </section>

    </main>

    <!-- ── Bottom Navigation (mobile) ──────────────────────────── -->
    <nav
      class="fixed bottom-0 w-full z-50 flex justify-around items-center h-20 px-4
             bg-background border-t-4 border-white
             shadow-[0px_-4px_0px_0px_rgba(255,121,198,1)] md:hidden"
      aria-label="Main navigation"
    >
      <div class="flex flex-col items-center justify-center bg-primary text-black w-16 h-16">
        <span class="material-symbols-outlined">grid_view</span>
        <span class="text-[10px] font-bold font-label uppercase tracking-widest">GRID</span>
      </div>
      <div
        class="flex flex-col items-center justify-center text-white opacity-50
               hover:bg-primary hover:text-black w-16 h-16 active:translate-y-1"
      >
        <span class="material-symbols-outlined">add_box</span>
        <span class="text-[10px] font-bold font-label uppercase tracking-widest">ADD</span>
      </div>
      <div
        class="flex flex-col items-center justify-center text-white opacity-50
               hover:bg-primary hover:text-black w-16 h-16 active:translate-y-1"
      >
        <span class="material-symbols-outlined">analytics</span>
        <span class="text-[10px] font-bold font-label uppercase tracking-widest">STATS</span>
      </div>
      <div
        class="flex flex-col items-center justify-center text-white opacity-50
               hover:bg-primary hover:text-black w-16 h-16 active:translate-y-1"
      >
        <span class="material-symbols-outlined">settings</span>
        <span class="text-[10px] font-bold font-label uppercase tracking-widest">META</span>
      </div>
    </nav>

    <!-- Populate today's date client-side (dd-mm-yyyy) -->
    <script is:inline>
      (function () {
        var now  = new Date();
        var day  = String(now.getDate()).padStart(2, '0');
        var mon  = String(now.getMonth() + 1).padStart(2, '0');
        var year = now.getFullYear();
        var el   = document.getElementById('today-date');
        if (el) el.textContent = day + '-' + mon + '-' + year;
      })();
    </script>

  </body>
</html>
