---
/**
 * Schedule.astro
 * Core exam schedule component.
 *
 * Architecture:
 *  - Frontmatter: imports hardcoded exam data from src/data/exams.ts (data contract).
 *  - Markup: renders one ExamCard React island per exam.
 *  - Each ExamCard runs a per-second countdown via useCountdown and
 *    renders the correct urgency-state variant (far/approaching/critical/
 *    last24/today/missed) from the client-side countdown engine.
 *
 * Date format convention: DD-MM-YYYY for all displayed dates (examDateDisplay field).
 * Countdown engine: src/lib/countdown.ts + src/hooks/useCountdown.ts
 * Data contract: src/data/exams.ts — update EXAMS array each deployment cycle.
 * Visual reference: stitch/…/Exam-Tracker-Deadline-Machine.html
 */

import { EXAMS } from '../data/exams';
import ExamCard from './ExamCard';
---

<div class="space-y-10">
  {EXAMS.map((exam) => (
    <ExamCard exam={exam} client:load />
  ))}
</div>
